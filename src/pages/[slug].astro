---
import Collage from "../components/collage.astro";
import ByaCollage from "../components/bya_collage.astro";
import Base from "../layouts/base.astro";
import { loadSections } from "../data/sections";

export async function getStaticPaths() {
    return loadSections().map((section) => ({
        params: { slug: section.slug },
        props: { section },
    }));
}

const { section } = Astro.props;
---
<Base pageTitle={section.title} inPage>
    <div class="flex flex-col gap-4 items-center justify-center text-white mb-4">
        <h1 class="text-3xl md:text-4xl font-medium text-c-white uppercase mb-3">{section.title}</h1>
        {section.type === "bya" ? (
            <ByaCollage />
        ) : (
            <Collage
                name={section.slug}
                horWidth={section.horWidth}
                verWidth={section.verWidth}
            />
        )}
    </div>
</Base>
